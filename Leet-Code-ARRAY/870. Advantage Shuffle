class Solution {
public:
    vector<int> advantageCount(vector<int>& nums1, vector<int>& nums2) {
        int n = nums1.size();
        vector<int>ans(n,-1);
        vector<pair<int,int>>v;
        for(int i=0;i<n;i++){
            v.push_back({nums2[i],i});
        }
        sort(v.begin(),v.end());
        vector<int>e;
        priority_queue<int,vector<int>,greater<int>>pq(nums1.begin(),nums1.end());
        int i=0;
        while(!pq.empty()){
            auto curr = pq.top();
            pq.pop();
            if(v[i].first<curr){
                ans[v[i].second] = curr;
                i++;
            }
            else{
                e.push_back(curr);
            }
        }
        for(int i=0;i<n;i++){
            if(ans[i]==-1){
                ans[i] = e.back();
                e.pop_back();
            }
        }
        return ans;
    }
};
