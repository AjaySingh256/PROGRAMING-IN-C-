class Solution {
public:
    int findKthLargest(vector<int>& nums, int k) {
        int n= nums.size();
        priority_queue<int> ans;
        for(int i=0;i<n;i++){
          ans.push(nums[i]);
        }
        int result=0;
        while(k>0){
            result = ans.top();
            ans.pop();
            k--;
        }
        return result;
    }
};
